# --- AI Configuration ---
# Your Gemini API Key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# --- Security & Auth Configuration ---
# Generate a secure 32-byte hex key for production
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# (Optional) Google Client ID if you verify the audience for Google Login
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# --- Database Configuration (Supabase & Prisma) ---
# Connect to Supabase via connection pooling (used by Prisma Client for standard queries)
DATABASE_URL="postgresql://username:password@host:6543/postgres?sslmode=require&pgbouncer=true"

# Direct connection to the database (used by Prisma for migrations like `prisma db push`)
DIRECT_URL="postgresql://username:password@host:5432/postgres?sslmode=require"

# Supabase details
NEXT_PUBLIC_SUPABASE_URL="https://your_project_ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key_here"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"
